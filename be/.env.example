# ── Required ──────────────────────────────────────────────────────────────────

# Set automatically by docker-compose; only needed when running outside Docker.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/internship

JWT_SECRET=change-me-to-a-long-random-string

# ── AI / LLM ─────────────────────────────────────────────────────────────────

GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash   # optional, this is the default

# ── RAG / Embeddings (optional) ───────────────────────────────────────────────

OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small   # optional, this is the default

# Required only when running the 'rag' compose profile (chromadb service).
# CHROMA_URL=http://chroma:8000
