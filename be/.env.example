# ── Required ──────────────────────────────────────────────────────────────────

# Set automatically by docker-compose; only needed when running outside Docker.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/internship

JWT_SECRET=change-me-to-a-long-random-string

# ── AI / LLM ─────────────────────────────────────────────────────────────────

GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash   # optional, this is the default

# ── RAG / Embeddings (optional) ───────────────────────────────────────────────

OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small   # optional, this is the default

# Required only when running the 'rag' compose profile (chromadb service).
# CHROMA_URL=http://chroma:8000

# ── Observability (optional) ───────────────────────────────────────────────────
# Toggle OpenTelemetry tracing
OTEL_ENABLED=true
# Service name shown in Jaeger
OTEL_SERVICE_NAME=internship-management-be
# OTLP endpoint (Jaeger all-in-one exposes 4318)
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
# OTLP traces endpoint (overrides OTEL_EXPORTER_OTLP_ENDPOINT if provided)
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://jaeger:4318/v1/traces

# Structured log level for JSON logs (shipped by Fluent Bit)
LOG_LEVEL=info
