# NEXT_PUBLIC_API_BASE_URL is baked into the JS bundle at build time (next build).
# Runtime env vars in Docker/Kubernetes do NOT change what the browser loads — you must
# rebuild the image with the correct --build-arg (see fe/Dockerfile).
#
# Use the URL the end-user's browser can reach (usually your API ingress), e.g.
#   https://api.example.com
# Do NOT use cluster-internal DNS here (e.g. *.svc.cluster.local) — the browser runs
# outside the cluster and cannot resolve or route to it.
#
# Local dev / docker compose: often http://localhost:3001 (see docker-compose.yml).
# Production: pass via CI build-arg (e.g. vars.NEXT_PUBLIC_API_BASE_URL_PRODUCTION in release.yml).
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
